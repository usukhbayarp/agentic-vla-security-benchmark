FROM nvcr.io/nvidia/pytorch@sha256:417cbf33f87b5378849df37983552cd1f8bc8b62fe1ceabe004de816a55dff21

ARG VLLM_REF=v0.12.0
ARG TORCH_CUDA_ARCH_LIST=12.1+PTX
ARG MAX_JOBS=8
ARG NVCC_THREADS=2

ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    MAX_JOBS=${MAX_JOBS} \
    NVCC_THREADS=${NVCC_THREADS} \
    VLLM_USE_TRITON_FLASH_ATTN=0 \
    TORCHINDUCTOR_MAX_AUTOTUNE=0

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --upgrade pip

RUN git clone --branch ${VLLM_REF} --depth 1 https://github.com/vllm-project/vllm.git /tmp/vllm
WORKDIR /tmp/vllm

# Record the exact source commit used for this build.
RUN git rev-parse HEAD > /vllm_commit.txt

RUN python3 use_existing_torch.py
RUN python3 -m pip install --break-system-packages -r requirements/build.txt
RUN python3 -m pip install --break-system-packages --no-build-isolation .

WORKDIR /
RUN rm -rf /tmp/vllm

# Store build metadata inside the image for later inspection.
RUN echo "VLLM_REF=${VLLM_REF}" > /vllm_meta.env && \
    echo "VLLM_COMMIT=$(cat /vllm_commit.txt)" >> /vllm_meta.env

# Runtime-configurable settings:
# - VLLM_API_KEY
# - VLLM_GPU_MEMORY_UTILIZATION
CMD ["bash", "-lc", "python3 -m vllm.entrypoints.openai.api_server \
  --model Qwen/Qwen3-VL-4B-Instruct \
  --revision ebb281ec70b05090aa6165b016eac8ec08e71b17 \
  --dtype bfloat16 \
  --max-model-len 8192 \
  --enforce-eager \
  --generation-config vllm \
  --api-key ${VLLM_API_KEY:-token-abc123} \
  --gpu-memory-utilization ${VLLM_GPU_MEMORY_UTILIZATION:-0.15} \
  --host 0.0.0.0 \
  --port 8000"]