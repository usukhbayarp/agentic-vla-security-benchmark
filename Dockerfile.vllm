FROM nvcr.io/nvidia/pytorch@sha256:417cbf33f87b5378849df37983552cd1f8bc8b62fe1ceabe004de816a55dff21

ARG VLLM_REF=v0.12.0
ARG TORCH_CUDA_ARCH_LIST=12.1+PTX
ARG MAX_JOBS=8
ARG NVCC_THREADS=2

ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive
ENV TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST}
ENV MAX_JOBS=${MAX_JOBS}
ENV NVCC_THREADS=${NVCC_THREADS}
ENV VLLM_USE_TRITON_FLASH_ATTN=0

RUN apt-get update && apt-get install -y \
    git \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --upgrade pip

RUN git clone --branch ${VLLM_REF} --depth 1 https://github.com/vllm-project/vllm.git /tmp/vllm
WORKDIR /tmp/vllm

RUN python3 use_existing_torch.py
RUN python3 -m pip install --break-system-packages -r requirements/build.txt
RUN python3 -m pip install --break-system-packages --no-build-isolation .
RUN python3 -m pip install --break-system-packages --upgrade triton

WORKDIR /
RUN rm -rf /tmp/vllm

CMD ["python3", "-m", "vllm.entrypoints.openai.api_server", \
     "--model", "Qwen/Qwen3-VL-4B-Instruct", \
     "--revision", "ebb281ec70b05090aa6165b016eac8ec08e71b17", \
     "--dtype", "bfloat16", \
     "--max-model-len", "8192", \
     "--gpu-memory-utilization", "0.4", \
     "--generation-config", "vllm", \
     "--api-key", "token-abc123", \
     "--host", "0.0.0.0", \
     "--port", "8000"]